# â”€â”€â”€ Ante Social AI Agent â€” Environment Variables â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Copy this to .env and fill in the values

# â”€â”€â”€ MongoDB (same as backend) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
MONGODB_URI=your_mongodb_uri_here

# â”€â”€â”€ Backend API â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Which market-engine port to call
MARKET_ENGINE_URL=http://127.0.0.1:3003
AUTH_SERVICE_URL=http://127.0.0.1:3002

# â”€â”€â”€ AI Agent Auth â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# MongoDB _id of the ante-agent system user (created by seed-ai-agent.ts)
AI_AGENT_USER_ID=

# JWT for the ante-agent user. Get it by running: npm run seed:jwt
# Or: POST http://localhost:3002/auth/login { "email": "ante-agent@antesocial.co.ke", "password": "your_password" }
AI_AGENT_JWT=

# â”€â”€â”€ AI Model â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# â”€â”€â”€ Data Sources â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
NEWSAPI_KEY=your_newsapi_key_here
SPORTRADAR_API_KEY=your_sportradar_api_key_here

# APIFY for Twitter scraping â€” sign up at apify.com (free tier works)
APIFY_TOKEN=

# â”€â”€â”€ Optional Redis Cache â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Uses same Redis instance as backend to de-dup market creation checks
REDIS_URL=your_redis_url_here

# â”€â”€â”€ Scheduler â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Timezone for all cron jobs (East Africa Time)
TZ=Africa/Nairobi
# Run market discovery: '0 */6 * * *' = every 6 hours | '*/5 * * * *' = every 5min for testing
DISCOVERY_CRON=0 */6 * * *
# Run resolution checks: '0 * * * *' = every hour
RESOLUTION_CRON=0 * * * *

# â”€â”€â”€ Agent Config â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Minimum confidence score to auto-post a market (0-100)
MIN_CONFIDENCE_TO_POST=80
# Minimum confidence to auto-settle (0-100)
MIN_CONFIDENCE_TO_SETTLE=95
# Max markets to create per discovery run
MAX_MARKETS_PER_RUN=10
# Default buy-in amount
DEFAULT_BUY_IN=100
# High value threshold for extra resolution sources
HIGH_VALUE_POOL_THRESHOLD=1000000
# Polymarket resolution toggle + API base
RESOLVE_POLYMARKET=true
POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com

# Source toggles
ENABLE_RSS=true
ENABLE_NEWSAPI=true
ENABLE_SPORTRADAR=true
ENABLE_APIFY=true
ENABLE_OFFICIAL_SOURCES=true
ENABLE_REDDIT=true
ENABLE_FACEBOOK=false
FACEBOOK_ACCESS_TOKEN=

# â”€â”€â”€ Monitoring / Alerts â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
LOG_LEVEL=info
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_APP_ID=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_VERIFICATION_TOKEN=
MONTHLY_BUDGET_USD=200

# AI agent admin server
AI_AGENT_HTTP_ENABLED=true
AI_AGENT_HTTP_HOST=0.0.0.0
AI_AGENT_HTTP_PORT=4010

# â”€â”€â”€ Environment â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
NODE_ENV=development
RUN_AI_TESTS=false



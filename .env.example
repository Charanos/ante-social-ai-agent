# ─── Ante Social AI Agent — Environment Variables ───────────────────────────
# Copy this to .env and fill in the values

# ─── MongoDB (same as backend) ───────────────────────────────────────────────
MONGODB_URI=your_mongodb_uri_here

# ─── Backend API ─────────────────────────────────────────────────────────────
# Which market-engine port to call
MARKET_ENGINE_URL=http://127.0.0.1:3003

# ─── AI Agent Auth ───────────────────────────────────────────────────────────
# MongoDB _id of the ante-agent system user (created by seed-ai-agent.ts)
AI_AGENT_USER_ID=

# JWT for the ante-agent user. Get it by running: npm run seed:jwt
# Or: POST http://localhost:3002/auth/login { "email": "ante-agent@antesocial.co.ke", "password": "your_password" }
AI_AGENT_JWT=

# ─── AI Model ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Data Sources ────────────────────────────────────────────────────────────
NEWSAPI_KEY=your_newsapi_key_here
SPORTRADAR_API_KEY=your_sportradar_api_key_here

# APIFY for Twitter scraping — sign up at apify.com (free tier works)
APIFY_TOKEN=

# ─── Optional Redis Cache ────────────────────────────────────────────────────
# Uses same Redis instance as backend to de-dup market creation checks
REDIS_URL=your_redis_url_here

# ─── Scheduler ───────────────────────────────────────────────────────────────
# Timezone for all cron jobs (East Africa Time)
TZ=Africa/Nairobi
# Run market discovery: '0 */6 * * *' = every 6 hours | '*/5 * * * *' = every 5min for testing
DISCOVERY_CRON=0 */6 * * *
# Run resolution checks: '0 * * * *' = every hour
RESOLUTION_CRON=0 * * * *

# ─── Agent Config ────────────────────────────────────────────────────────────
# Minimum confidence score to auto-post a market (0-100)
MIN_CONFIDENCE_TO_POST=80
# Minimum confidence to auto-settle (0-100)
MIN_CONFIDENCE_TO_SETTLE=95
# Max markets to create per discovery run
MAX_MARKETS_PER_RUN=10
# Default buy-in amount in USD
DEFAULT_BUY_IN=100

# ─── Monitoring / Alerts ─────────────────────────────────────────────────────
LOG_LEVEL=info
SLACK_WEBHOOK_URL=
MONTHLY_BUDGET_USD=200

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=development
